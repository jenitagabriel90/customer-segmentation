      <column caption='Customer Segment' datatype='string' name='[Calculation_1037996866760710]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Annual Income (k$)] &gt;= 70 AND [Spending Score (1-100)] &gt;= 70 THEN &quot;High Income, High Spending&quot;&#13;&#10;&#13;&#10;ELSEIF [Annual Income (k$)] &gt;= 70 AND [Spending Score (1-100)] &lt; 40 THEN &quot;High Income, Low Spending&quot;&#13;&#10;&#13;&#10;ELSEIF [Annual Income (k$)] &lt; 40 AND [Spending Score (1-100)] &gt;= 70 THEN &quot;Low Income, High Spending&quot;&#13;&#10;&#13;&#10;ELSEIF [Annual Income (k$)] &lt; 40 AND [Spending Score (1-100)] &lt; 40 THEN &quot;Low Income, Low Spending&quot;&#13;&#10;&#13;&#10;ELSE &quot;Medium Income, Medium Spending&quot;&#13;&#10;END' />
        <aliases>
          <alias key='&quot;High Income, High Spending&quot;' value='Premium' />
          <alias key='&quot;High Income, Low Spending&quot;' value='Careful' />
          <alias key='&quot;Low Income, High Spending&quot;' value='Impulsive' />
          <alias key='&quot;Low Income, Low Spending&quot;' value='Budget' />
          <alias key='&quot;Medium Income, Medium Spending&quot;' value='Standard' />
        </aliases>
      </column>
      <column caption='Age Group' datatype='string' name='[Calculation_1037996868710407]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Age] &lt; 20 THEN &quot;Under 20&quot;&#13;&#10;ELSEIF [Age] &gt;= 20 AND [Age] &lt; 30 THEN &quot;20-29&quot;&#13;&#10;ELSEIF [Age] &gt;= 30 AND [Age] &lt; 40 THEN &quot;30-39&quot;&#13;&#10;ELSEIF [Age] &gt;= 40 AND [Age] &lt; 50 THEN &quot;40-49&quot;&#13;&#10;ELSE &quot;50+&quot;&#13;&#10;END' />
      </column>
      <column caption='Income Group' datatype='string' name='[Calculation_1037996868821000]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Annual Income (k$)] &lt; 30 THEN &quot;Low Income&quot;&#13;&#10;ELSEIF [Annual Income (k$)] &gt;= 30 AND [Annual Income (k$)] &lt; 60 THEN &quot;Middle Income&quot;&#13;&#10;ELSE &quot;High Income&quot;&#13;&#10;END' />
      </column>
      <column caption='Spending Group' datatype='string' name='[Calculation_1037996868907017]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Spending Score (1-100)] &lt; 40 THEN &quot;Low Spender&quot;&#13;&#10;ELSEIF [Spending Score (1-100)] &gt;= 40 AND [Spending Score (1-100)] &lt; 70 THEN &quot;Medium Spender&quot;&#13;&#10;ELSE &quot;High Spender&quot;&#13;&#10;END' />
      </column>
